{
  "manifest_version": 3,
  "name": "CustomPlaceDB",
  "version": "1.0",
  "description": "커스텀 필드로 나만의 장소 데이터베이스를 만들어보세요",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://map.naver.com/*",
    "https://pcmap.place.naver.com/*",
    "https://map.kakao.com/*",
    "https://place.map.kakao.com/*",
    "https://maps.google.com/*",
    "https://www.google.com/*",
    "https://www.google.co.kr/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://map.naver.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://map.kakao.com/*", "https://place.map.kakao.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://maps.google.com/*", "https://www.google.com/maps*", "https://www.google.co.kr/maps*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CustomPlaceDB"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}